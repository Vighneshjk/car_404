SECRET_KEY=django-insecure-404-car-care-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - Using SQLite for dev, switch to PostgreSQL for prod
DATABASE_URL=sqlite:///db.sqlite3

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Company Info
COMPANY_NAME=404 Car Care
COMPANY_PHONE=+91-9999999999
COMPANY_EMAIL=info@404carcare.com
